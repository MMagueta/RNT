{
    "version": 3,
    "configurePresets": [
        {
            "name": "windows-debug",
            "displayName": "Windows Debug",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "NT_WAIT_ON_EXIT": "ON"
            }
        },
        {
            "name": "windows-release",
            "displayName": "Windows Release",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "NT_WAIT_ON_EXIT": "OFF"
            }
        },
        {
            "name": "unix-debug",
            "displayName": "Unix Debug",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "NT_WAIT_ON_EXIT": "ON"
            }
        },
        {
            "name": "unix-release",
            "displayName": "Unix Release",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "NT_WAIT_ON_EXIT": "OFF"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "windows-debug",
            "configurePreset": "windows-debug"
        },
        {
            "name": "windows-release",
            "configurePreset": "windows-release"
        },
        {
            "name": "unix-debug",
            "configurePreset": "unix-debug"
        },
        {
            "name": "unix-release",
            "configurePreset": "unix-release"
        }
    ]
}
